# Pin this to the LiveKit server version you have tested.
LIVEKIT_IMAGE=livekit/livekit-server:<pinned-version>

# Enable the optional control worker with `--profile control-worker`.
GROUP_CALL_CONTROL_URL=https://your-project.supabase.co/functions/v1/group-call-control
GROUP_CALL_CONTROL_SECRET=replace-with-a-long-random-secret
